# 使用說明：複製此檔案為 .env 並填入實際值
#   cp .env.example .env

# ── Supabase ─────────────────────────────
# 取得位置：https://supabase.com/dashboard/project/{PROJECT_ID}/settings/api

# Project URL（格式：https://xxxxx.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=

# anon public key（格式：eyJ... 或 sb_publishable_...）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
